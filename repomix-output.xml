}
.route-badge.web {
    background: rgba(67, 97, 238, 0.15);
    color: var(--accent-blue);
    border: 1px solid rgba(67, 97, 238, 0.3);
}
.route-badge.eligibility {
    background: rgba(255, 107, 53, 0.15);
    color: var(--accent-primary);
    border: 1px solid rgba(255, 107, 53, 0.3);
}

/* Sources Section */
.sources-section {
    margin-top: 12px;
    padding-top: 10px;
    border-top: 1px solid var(--border-color);
}

.sources-title {
    font-size: 11px;
    font-weight: 600;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 6px;
}

.source-item {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 4px 8px;
    margin-bottom: 3px;
    background: rgba(255, 255, 255, 0.03);
    border-radius: 6px;
    font-size: 11px;
    color: var(--text-secondary);
}

.source-item a {
    color: var(--accent-teal);
    text-decoration: none;
}
.source-item a:hover {
    text-decoration: underline;
}

/* Typing indicator */
.typing-indicator {
    display: flex;
    gap: 4px;
    padding: 4px 0;
}

.typing-indicator span {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: var(--text-secondary);
    animation: typingBounce 1.4s infinite ease-in-out;
}

.typing-indicator span:nth-child(1) { animation-delay: 0s; }
.typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
.typing-indicator span:nth-child(3) { animation-delay: 0.4s; }

@keyframes typingBounce {
    0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
    40% { transform: scale(1); opacity: 1; }
}

/* ═══════════════════════ CHAT INPUT ═══════════════════════ */
.chat-input-container {
    padding: 1rem 5rem;
    position: relative;
}

.chat-input-form {
    display: flex;
    align-items: center;
    gap: 8px;
    background-color: var(--bg-dark-card);
    border: 1px solid var(--border-color);
    border-radius: 14px;
    padding: 4px 6px;
    transition: border-color 0.2s, box-shadow 0.2s;
}

.chat-input-form:focus-within {
    border-color: var(--accent-primary);
    box-shadow: 0 0 0 3px rgba(255, 107, 53, 0.1);
}

.attach-btn {
    background: none;
    border: none;
    color: var(--text-secondary);
    cursor: pointer;
    padding: 8px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
}
.attach-btn:hover {
    background-color: rgba(255, 107, 53, 0.1);
    color: var(--accent-primary);
}

.chat-input {
    flex-grow: 1;
    border: none;
    background: transparent;
    color: var(--text-primary);
    padding: 10px 8px;
    font-size: 0.95rem;
    font-family: inherit;
}
.chat-input:focus {
    outline: none;
}
.chat-input::placeholder {
    color: var(--text-secondary);
}

.send-button {
    background: var(--gradient-orange);
    border: none;
    color: white;
    width: 38px;
    height: 38px;
    border-radius: 10px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    flex-shrink: 0;
}
.send-button:hover {
    transform: scale(1.05);
    box-shadow: var(--shadow-glow);
}
.send-button:disabled {
    opacity: 0.4;
    cursor: not-allowed;
    transform: none;
}

.attach-popover {
    display: none;
    position: absolute;
    bottom: 65px;
    left: 5rem;
    width: 220px;
    background-color: var(--bg-dark-card);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    z-index: 15;
    box-shadow: 0 -8px 30px rgba(0,0,0,0.4);
    overflow: hidden;
}
.attach-popover.show {
    display: block;
}
.attach-popover-item {
    padding: 10px 14px;
    cursor: pointer;
    transition: background 0.15s;
    font-size: 13px;
}
.attach-popover-item:hover {
    background: rgba(255, 107, 53, 0.1);
    color: var(--accent-primary);
}

/* LLM Model Select */
.llm-model-select {
    background-color: var(--bg-dark-element);
    color: var(--text-primary);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 7px 8px;
    font-size: 12px;
    cursor: pointer;
    transition: all 0.2s;
    font-family: inherit;
}
.llm-model-select:focus {
    outline: none;
    border-color: var(--accent-primary);
}
.llm-model-select:hover {
    border-color: var(--accent-primary);
}

/* File Preview */
.file-preview-wrapper {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    margin-bottom: 6px;
    background: var(--bg-dark-card);
    border: 1px solid var(--border-color);
    border-radius: 10px;
}

.file-preview-wrapper.hidden {
    display: none;
}

.file-preview-item {
    display: flex;
    align-items: center;
    gap: 8px;
}

.file-icon {
    padding: 4px 8px;
    background: var(--gradient-blue);
    border-radius: 6px;
    font-size: 10px;
    font-weight: 700;
    color: white;
}

.file-name {
    font-size: 12px;
    color: var(--text-secondary);
}

.file-remove-btn {
    background: none;
    border: none;
    color: var(--text-secondary);
    cursor: pointer;
    font-size: 16px;
    padding: 2px 6px;
    border-radius: 4px;
    transition: all 0.2s;
}
.file-remove-btn:hover {
    color: #ff4444;
    background: rgba(255, 68, 68, 0.1);
}

.file-thumbnail {
    max-width: 50px;
    max-height: 50px;
    object-fit: cover;
    border-radius: 6px;
}

/* ═══════════════════════ MODALS ═══════════════════════ */
.modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
}

.modal-content {
    background-color: var(--bg-dark-card);
    padding: 28px;
    border-radius: 16px;
    border: 1px solid var(--border-color);
    width: 90%;
    max-width: 420px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
}

.modal-content h3 {
    margin-top: 0;
    margin-bottom: 16px;
    color: var(--text-primary);
    font-size: 1.1rem;
}

.modal-body p {
    margin: 0 0 20px 0;
    color: var(--text-secondary);
    font-size: 14px;
}

.modal-input {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid var(--border-color);
    background-color: var(--bg-dark-main);
    color: var(--text-primary);
    border-radius: 10px;
    margin-bottom: 20px;
    box-sizing: border-box;
    font-family: inherit;
    font-size: 14px;
}
.modal-input:focus {
    outline: none;
    border-color: var(--accent-primary);
}

.modal-footer {
    display: flex;
    justify-content: flex-end;
    gap: 8px;
}

.modal-btn {
    padding: 8px 18px;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    font-weight: 600;
    font-size: 13px;
    transition: all 0.2s;
}

.modal-btn-primary {
    background: var(--gradient-orange);
    color: white;
}
.modal-btn-primary:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-glow);
}

.modal-btn-secondary {
    background-color: var(--bg-dark-element);
    color: var(--text-primary);
}
.modal-btn-secondary:hover {
    background-color: rgba(255, 255, 255, 0.08);
}

/* ═══════════════════════ TOAST ═══════════════════════ */
.toast-container {
    position: fixed;
    top: 20px;
    right: 20px;
    z-index: 2000;
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.toast {
    padding: 12px 20px;
    border-radius: 12px;
    font-size: 13px;
    font-weight: 500;
    box-shadow: 0 8px 30px rgba(0,0,0,0.3);
    animation: toastIn 0.3s ease, toastOut 0.3s ease 2.7s forwards;
    max-width: 350px;
}

.toast.success {
    background: var(--gradient-green);
    color: white;
}
.toast.error {
    background: linear-gradient(135deg, #e74c3c, #c0392b);
    color: white;
}
.toast.info {
    background: var(--gradient-blue);
    color: white;
}

@keyframes toastIn {
    from { opacity: 0; transform: translateX(30px); }
    to { opacity: 1; transform: translateX(0); }
}
@keyframes toastOut {
    from { opacity: 1; transform: translateX(0); }
    to { opacity: 0; transform: translateX(30px); }
}

/* ═══════════════════════ RESPONSIVE ═══════════════════════ */
@media (max-width: 768px) {
    .chat-area {
        padding: 0 1rem 1rem 1rem;
    }
    .chat-input-container {
        padding: 1rem;
    }
    .sidebar {
        width: 240px;
    }
    .suggestion-chips {
        flex-direction: column;
        align-items: center;
    }
    .chat-bubble {
        max-width: 90%;
    }
}
